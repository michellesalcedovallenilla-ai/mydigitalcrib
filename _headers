# Security headers applied to every response served by Cloudflare Pages.
# Keeps production at parity with the hardened local dev server.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdn.jsdelivr.net 'unsafe-eval' 'sha256-4V1UclJClx9/FV6gHP29z3mTvSralDNQnI7ho0PBBtY='; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'

# Long-cache static assets (the JS / CSS hashes change with content,
# but for a small site cache-busting via filename isn't set up yet â€”
# keep this conservative for now)
/*.js
  Cache-Control: public, max-age=300

/*.css
  Cache-Control: public, max-age=300

/IMAGES/*
  Cache-Control: public, max-age=86400, immutable

